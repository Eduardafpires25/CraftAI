# --- App ---
# Nível de log da aplicação (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Obrigatório. Padrão: INFO
LOG_LEVEL=INFO
# Modo de desenvolvimento (true/false). Quando true, habilita recursos de debug
# Obrigatório. Padrão: false
DEV_MODE=true

# --- Postgres ---
# Configurações do banco de dados PostgreSQL
# Todas são obrigatórias para o funcionamento da aplicação
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=craftai
POSTGRES_HOST=database
POSTGRES_PORT=5432

# --- JWT ---
# Chave secreta para assinatura de tokens JWT
# Obrigatório. Mude para uma string segura em produção
SECRET_KEY=change-me-in-production
# Algoritmo de criptografia JWT (HS256, RS256, etc.)
# Obrigatório. Padrão: HS256
ALGORITHM=HS256
# Tempo de expiração do token de acesso em minutos
# Obrigatório. Padrão: 30
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Tempo de expiração do token de refresh em dias
# Obrigatório. Padrão: 7
REFRESH_TOKEN_DAYS=7

# --- OpenAI / AI ---
# Chave da API da OpenAI para geração de texto e imagem
# Obrigatório se usar IA. Deixe vazio para desabilitar
OPENAI_API_KEY=
# URL base da API OpenAI (use para proxies ou endpoints alternativos)
# Opcional. Se não definido, usa o padrão da OpenAI
# OPENAI_BASE_URL=
# Modelo de texto da OpenAI (gpt-4o-mini, gpt-4, etc.)
# Obrigatório se usar IA. Padrão: gpt-4o-mini
OPENAI_TEXT_MODEL=gpt-4o-mini
# Modelo de imagem da OpenAI (gpt-image-2, dall-e-3, etc.)
# Obrigatório se usar IA. Padrão: gpt-image-2
OPENAI_IMAGE_MODEL=gpt-image-2
# Tamanho da imagem gerada (1024x1024, 512x512, etc.)
# Obrigatório se usar IA. Padrão: 1024x1024
OPENAI_IMAGE_SIZE=1024x1024
# Timeout em segundos para chamadas à API OpenAI
# Opcional. Padrão: 120
OPENAI_TIMEOUT_SECONDS=120
# Quando true, gera placeholder verde em vez de chamar OpenAI (para testes)
# Opcional. Padrão: true
AI_PLACEHOLDER_MODE=true
# Habilita limite diário de iterações de IA por usuário
# Opcional. Padrão: true
AI_ITERATIONS_LIMIT_ENABLED=true
# Limite diário de iterações de IA por usuário
# Opcional. Padrão: 5
AI_ITERATIONS_DAILY_LIMIT=5

# --- SMTP / Email ---
# Configurações para envio de emails (recuperação de senha, notificações, etc.)
# Opcional. Se não configurado, emails não serão enviados
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=email@gmail.com
SMTP_PASSWORD=password
SMTP_TLS=true
EMAIL_FROM=email@gmail.com
EMAIL_FROM_NAME=CraftAI

# --- Storage (local | s3) ---
# Backend de armazenamento de imagens
# Obrigatório. Padrão: local
STORAGE_BACKEND=local
# URL pública base para servir imagens locais
# Obrigatório para storage local. Padrão: /images
STORAGE_PUBLIC_URL_BASE=/images
# Limite de upload em MB
# Opcional. Padrão: 10
STORAGE_MAX_UPLOAD_MB=10

# S3 / DigitalOcean Spaces / MinIO (usado quando STORAGE_BACKEND=s3)
# URL do endpoint S3 (ex: https://nyc3.digitaloceanspaces.com para Spaces)
# Opcional. Se não definido, usa AWS S3 padrão
# S3_ENDPOINT_URL=https://nyc3.digitaloceanspaces.com
# Região do bucket S3
# Obrigatório para S3. Padrão: us-east-1
S3_REGION=us-east-1
# Nome do bucket S3
# Obrigatório para S3
S3_BUCKET=
# Chave de acesso S3
# Obrigatório para S3
S3_ACCESS_KEY=
# Chave secreta S3
# Obrigatório para S3
S3_SECRET_KEY=
# URL pública base do bucket/CDN
# Obrigatório para S3
S3_PUBLIC_URL_BASE=
# ACL padrão dos arquivos (public-read ou private)
# Opcional. Padrão: public-read
S3_DEFAULT_ACL=public-read
